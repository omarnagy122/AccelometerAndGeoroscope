<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sensor Reading App"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#BF360C"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <!-- ACCELEROMETER HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accelerometer"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:padding="10dp"/>

        <!-- ACCELEROMETER CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView android:id="@+id/tvAccX"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="X axis: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#C62828"
                android:paddingBottom="6dp"/>

            <TextView android:id="@+id/tvAccY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Y axis: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:paddingBottom="6dp"/>

            <TextView android:id="@+id/tvAccZ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Z axis: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingBottom="6dp"/>

            <TextView android:id="@+id/tvAccMagnitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Magnitude: --"
                android:textSize="13sp"
                android:paddingBottom="6dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/tvAccStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: --"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#6A1B9A"/>
        </LinearLayout>

        <!-- GYROSCOPE HEADER -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Gyroscope"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#4A148C"
            android:padding="10dp"/>

        <!-- GYROSCOPE CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView android:id="@+id/tvGyroX"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rotation X: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#C62828"
                android:paddingBottom="6dp"/>

            <TextView android:id="@+id/tvGyroY"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rotation Y: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:paddingBottom="6dp"/>

            <TextView android:id="@+id/tvGyroZ"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rotation Z: --"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:paddingBottom="6dp"/>

            <TextView android:id="@+id/tvGyroMagnitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Magnitude: --"
                android:textSize="13sp"
                android:paddingBottom="6dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="6dp"/>

            <TextView android:id="@+id/tvGyroStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: --"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#4A148C"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>